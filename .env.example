# Database (auto-injected by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/cardova

# Redis (auto-injected by Railway Redis plugin)
REDIS_URL=redis://default:password@host:6379

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_monthly_id
STRIPE_PRO_LIFETIME_PRICE_ID=price_lifetime_id

# Cloudinary (optional — if not set, uses Railway Volume)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Railway Volume mount path (if not using Cloudinary)
RAILWAY_VOLUME_MOUNT_PATH=/data/uploads

# Frontend URL (for CORS)
CLIENT_URL=https://cardova.net

# API URL (used by frontend)
VITE_API_URL=https://api.cardova.net

# Email (optional, for contact notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Server
PORT=3000
NODE_ENV=production
