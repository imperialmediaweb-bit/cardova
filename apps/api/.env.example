# Database — auto-injected by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/cardova

# Redis — auto-injected by Railway Redis plugin
REDIS_URL=redis://default:password@host:6379

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe price IDs — create in Stripe Dashboard > Products
STRIPE_MONTHLY_PRICE_ID=price_monthly_id
STRIPE_LIFETIME_PRICE_ID=price_lifetime_id

# Cloudinary — https://cloudinary.com/console (optional)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Storage path — used if CLOUDINARY_URL not set (Railway Volume mount)
STORAGE_PATH=/data/uploads

# SMTP — for transactional emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Cardova <noreply@cardova.net>

# Frontend URL — for CORS + email links
CLIENT_URL=https://cardova.net

# Server
PORT=3000
NODE_ENV=production
